## source function library ##
# shellcheck source=/home/rick/bin/functionlib
source ~/bin/functionlib || { printf "\e[91mERROR:\e[0m Unable to source functionlib\n"; exit 1; }

## Global Variables ##

readonly script="${0##*/}"
readonly version="4.0.26151"

## Functions ##

help() {
	local errcode="${1:-1}"
	local updated="31 May 2026"
	cat << _HELP_
${orange}$script${normal} $version ($updated)
Scans a range of IP addresses to determine if they are online.

${green}Usage:${normal} $script IP1 IP2
${orange}Example:${normal} $script 10 20
Takes 2 integer arguments between 1 and 254 (last octets of address).
First argument must be less than the second.
_HELP_
	exit "$errcode"
}

check_arg_values() {
	# returns TRUE only if both octets are inegers within the valid range of valid IP addresses.
	local ip1="$1"
	local ip2="$2"
	local re="^[0-9]+$"
	[[ "$ip1" =~ $re && "$ip2" =~ $re ]] 2>/dev/null || { printf "%s non-integer value\n" "$RED_ERROR" <&2; return "$FALSE"; }
	[[ "$ip1" -ge "$ip2" ]] && { printf "%s Invalid range\n" "$RED_ERROR" <&2; return "$FALSE"; }
	[[ "$ip1" -lt 1 || "$ip2" -gt 254 ]] && { printf "%s Invalid range\n" "$RED_ERROR" <&2; return "$FALSE"; }
	return "$TRUE"
}

scan_range() {
	local ip ip1 ip2
	ip1="$1"
	ip2="$2"
	for (( ip=ip1; ip<=ip2; ip++ )); do
		printf "%s.%d " "$LOCALNET" "$ip"
		grep -E "0 response|0 packets received" < <(arping -c 1 "$LOCALNET.$ip") > /dev/null && printf "didn't respond.\n" || printf "responded.\n"
	done
}

main() {
	[[ $# -lt 2 ]] && { printf "%s Too few arguments passed.\n" "$RED_ERROR" <&2; help "$E_MISSING_ARG"; }
	local addr1="$1"
	local addr2="$2"
	check_arg_values "$addr1" "$addr2" || help "$E_INVALID_ARG"
	check_package iputils-arping
	scan_range "$addr1" "$addr2"
	over_line "$script $version"
	exit
}

## Execution ##

main "$@"

## Load function library ##
# shellcheck source=/home/rick/bin/functionlib
source functionlib || { printf "\e[91mERROR:\e[0m Unable to source functionlib\n"; exit 1; }

## Functions ## 0

title_box() {
  local -r lhost="$1"
  echo -n "${lightyellow}"
  box "IP Information - $lhost" "*"
  echo "${normal}"

}

# Some systems may require root access for the iw command. Replace foo-bar with these hostnames.
requires_sudo() {
	local lhost="$1"
  case "$lhost" in
    foo-bar )
      return "$TRUE" ;;
    * )
      return "$FALSE"
  esac
}

check_dependencies() {
  local packages=( curl iw network-manager )
  check_packages "${packages[@]}"
}

show_public_ip() {
  local public_ipv4 public_ipv6
  printf "%sPublic IP:%s\n" "$orange" "$normal"
  public_ipv4=$(/usr/bin/curl -s -4 ifconfig.me)
  [[ "$public_ipv4" ]] && printf "%4sIPv4: %s\n" " " "$public_ipv4" || printf "%4sIPv4: No address found.\n" " "
  public_ipv6=$(/usr/bin/curl -s -6 icanhazip.com)
  [[ "$public_ipv6" ]] && printf "%8s: %s\n" "IPv6" "$public_ipv6" || printf "%4sIPv6: No address found.\n" " "
}

show_wired() {
  # Assumes only one active ethernet wired interface in the system.
  local eth_int eth_state eth_ip eth_mac eth_str
  printf -v eth_str "%s%12s:%s" "$lightgreen" "Ethernet" "$normal"
  eth_int=$(awk '/ethernet/ {print $1}' <(/usr/bin/nmcli dev))
   [[ "$eth_int" ]] || return
  # interface data
  eth_state=$(cat "/sys/class/net/$eth_int/operstate")
  eth_ip=$(awk '/IP4.ADDRESS/ {print $NF}' <(/usr/bin/nmcli dev show "$eth_int") | sed 's/\/24//')
  eth_mac=$(awk '/GENERAL.HWADDR/ {print $NF}' <(/usr/bin/nmcli dev show "$eth_int"))
  # display status
  case "$eth_state" in
    up )
      printf "%s %s\n" "$eth_str" "$eth_ip"
      printf "%12s: %s\n" "Device" "$eth_int"
      printf "%12s: %s\n" "MAC" "$eth_mac"
      ;;
    down )
      printf "%s Not connected\n" "$eth_str"
      printf "%12s: %s\n" "Device" "$eth_int"
      printf "%12s: %s\n" "MAC" "$eth_mac"
      ;;
    unknown )
      printf "%s Unknown state\n" "$eth_str"
      printf "%12s: %s\n" "Device" "$eth_int"
      printf "%12s: %s\n" "MAC" "$eth_mac"
      ;;
    * )
      printf "%4sNo device found.\n" " "
  esac
}

show_wireless() {
  # Assumes only one active wireless interface in the system.
  local wifi_int wifi_state wifi_ip wifi_mac wifi_ssid wifi_sig wifi_str
  printf -v wifi_str "%s%12s:%s" "$lightgreen" "Wireless" "$normal"
  wifi_int=$(awk '/wifi / {print $1}' <(/usr/bin/nmcli dev))
  [[ "$wifi_int" ]] || return
  # interface data
  wifi_state=$(cat "/sys/class/net/$wifi_int/operstate")
  wifi_ip=$(awk '/IP4.ADDRESS/ {print $NF}' <(/usr/bin/nmcli dev show "$wifi_int") | sed 's/\/24//')
  wifi_mac=$(awk '/GENERAL.HWADDR/ {print $NF}' <(/usr/bin/nmcli dev show "$wifi_int"))
  if requires_sudo; then
    wifi_ssid=$(awk '/SSID/ {print $2}' <(sudo /sbin/iw dev "$wifi_int" link))
    wifi_sig=$(awk '/signal/ {print $2,$3}' <(sudo /sbin/iw dev "$wifi_int" link))
  else
    wifi_ssid=$( awk '/SSID/ {print $2}' <(/sbin/iw dev "$wifi_int" link))
    wifi_sig=$(awk '/signal/ {print $2,$3}' <(/sbin/iw dev "$wifi_int" link))
  fi
  [[ "$wifi_ssid" ]] || wifi_ssid="Not available"
  [[ "$wifi_sig" ]] || wifi_sig="Not available"
  # display status
  case "$wifi_state" in
    up )
      printf "%s %s\n" "$wifi_str" "$wifi_ip"
      printf "%12s: %s\n" "Device" "$wifi_int"
      printf "%12s: %s\n" "MAC" "$wifi_mac"
      printf "%12s: %s\n" "SSID" "$wifi_ssid"
      printf "%12s: %s\n" "Signal" "$wifi_sig"
      ;;
    down )
      printf "%s Not connected\n" "$wifi_str"
      printf "%12s: %s\n" "Device" "$wifi_int"
      printf "%12s: %s\n" "MAC" "$wifi_mac"
      ;;
    unknown )
      printf "%s Unknown state\n" "$wifi_str"
      printf "%12s: %s\n" "Device" "$wifi_int"
      printf "%12s: %s\n" "MAC" "$wifi_mac"
      ;;
    * )
      printf "%4sNo device found.\n" " "
  esac
}

show_bridge() {
  local br_int br_state br_ip br_mac br_route br_str
  printf -v br_str "%s%12s:%s" "$lightgreen" "Wireless" "$normal"
	br_int=$(awk '/bridge / {print $1}' <(/usr/bin/nmcli dev))
	[[ "$br_int" ]] || return
  # interface data
  br_state=$(cat "/sys/class/net/$br_int/operstate")
  br_ip=$(awk '/vir/ && /brd/ {print $2}' <(ip addr show))
  br_mac=$(cat "/sys/class/net/$br_int/address")
  br_route=$(awk '/vir/ && /kernel/ {print $1}' <(ip route show))
  # display status
  case "$br_state" in
    up )
      printf "%s %s\n" "$br_str" "$br_ip"
      printf "%12s: %s\n" "Device" "$br_int"
      printf "%12s: %s\n" "MAC" "$br_mac"
	    printf "%12s: %s\n" "Subnet" "$br_route"
      ;;
    down )
      printf "%s Not connected\n" "$br_str"
      printf "%12s: %s\n" "Device" "$br_int"
      printf "%12s: %s\n" "MAC" "$br_mac"
      ;;
    unknown )
      printf "%s Unknown state\n" "$br_str"
      printf "%12s: %s\n" "Device" "$br_int"
      printf "%12s: %s\n" "MAC" "$br_mac"
      ;;
    * )
      printf "%4sNo device found.\n" " "
  esac
}

show_network() {
  local network_addr
  network_addr=$(awk '/kernel/ {print $1;exit}' <(ip route show))
  # network_addr=$(awk '/kernel/ {print $1}' <(ip route show) | sort -u) # work with KCM/QEMU or Gnome Boxes?
  printf "%sLocal Network:%s\n" "$orange" "$normal"
  printf "%4s%s\n" " " "$network_addr"
}

show_gateway() {
  local gateway_addr
  gateway_addr=$(awk 'NR==1 {print $3}' <(ip route get 1.2.3.4))
  printf "%sDefault Gateway:%s\n" "$orange" "$normal"
  printf "%4s%s\n" " " "$gateway_addr"
}

show_dns() {
  local addr dns_addrs
  printf "%sDNS Servers:%s\n" "$orange" "$normal"
  readarray -t dns_addrs <<< "$(awk '/IP4.DNS/ {print $NF}' <(/usr/bin/nmcli dev show) | sort -ru)"
  for addr in "${dns_addrs[@]}"; do printf "%4s%s\n" " " "$addr"; done
}

main() {
  local -r script="${0##*/}"
  local -r version="5.0.26113"
  local -r lhost="${HOSTNAME:-$(hostname)}"
  requires_sudo "$lhost" && sudo_login 2
  check_dependencies
  clear
  title_box "$lhost"
  show_public_ip
  printf "%sLocal IP:%s\n" "$orange" "$normal"
  show_wired
  show_wireless
  show_bridge
  show_network
  show_gateway
  show_dns
  over_line "$script $version"
  exit
}

## Execution ##

main "$@"

## Source function library ##
# shellcheck source=/home/rick/bin/functionlib
source ~/bin/functionlib || { printf "\e[91mERROR:\e[0m Unable to source functionlib\n"; exit 1; }

## Functions ##

help() {
  local -r script="$1"
  local -r version="$2"
	local errcode="${3:-1}"
  local -r updated="01 Jul 2026"
  cat <<- _HELP_
	${orange}$script${normal} $version (updated $updated)
	Displays a text file using either cat or less depending the number of lines in
	the file and the number of rows in the current terminal window. Less is used when
	the number of lines is greater than the 87% of the rows, otherwise cat is used.

	${green}Usage:${normal} $script [-h] filename [-n|n]
	${orange}Available options:${normal}
	  -h  Show this help message and exit.
	  -n  enable line numbers (follows filename and is case-insensitive).
	_HELP_
  exit "$errcode"
}

over_max() {
	# Returns TRUE (0) if number of lines in file > number of rows in terminal
	local -r textfile="$1"
	local catmax filelines
	catmax=$(( $(tput lines)*87/100 ))
	filelines=$(wc -l < "$textfile")
	(( filelines > catmax )) && return "$TRUE" || return "$FALSE"
}

check_file() {
	local -r filename="$1"
	if [[ ! -f "$filename" ]]; then
		printf "%s %s not found.\n" "$RED_ERROR" "$filename" >&2
		return "$FALSE"
	elif [[ ! -s "$filename" ]]; then
		printf "%s %s is an empty file.\n" "$RED_ERROR" "$filename" >&2
		return "$FALSE"
	elif grep -qEi "text|json" < <(file -bL "$filename"); then
		return "$TRUE"
	else
		printf "%s %s is not a valid text file.\n" "$RED_ERROR" "$filename" >&2
		return "$FALSE"
	fi
}

view_file() {
  local -r textfile="$1"
  local -r num_flag="$2"
  if over_max "$textfile"; then
    case "$num_flag" in
      0 )
        less -N "$textfile" ;;
      * )
        less "$textfile"
    esac
    head -n5 "$textfile"
  else
    case "$num_flag" in
      0 )
        cat -n "$textfile" ;;
      * )
        cat "$textfile"
    esac
  fi
  printf "%sFile: %s%s\n" "$reverse" "$textfile" "$normal"
	return 0
}

main() {
	local -r script="${0##*/}"
	local -r version="8.0.26182"
	local -i exit_code=0
	local num_flag=
	[[ $1 == "-h" ]] && help "$script" "$version" 0
	local -r filename="$1"
	local num_opt="${2,,}"		# make argument lowercase
	num_opt="${num_opt:0:2}"	# take 1st two characters
	[[ "$num_opt" == "-n" || "$num_opt" == "n" ]] && num_flag="$TRUE" || num_flag="$FALSE"
	check_file "$filename" && view_file "$filename" "$num_flag"
	exit_code="$?"
	over_line "$script $version"
	exit "$exit_code"
}

## Execution ##

main "$@"

## Source function library ##
# shellcheck source=/home/rick/bin/functionlib
source ~/bin/functionlib || { printf "\e[91mERROR:\e[0m Unable to source functionlib\n"; exit 1; }

## Functions ##

help() {
  local -r script="$1"
  local -r version="$2"
  local -r errcode="${3:-1}"
  local -r updated="03 Jul 2026"
  cat << _HELP_
${orange}$script${normal} $version, updated: $updated
Creates fortune cookie files for the fortune program.

${green}Usage:${normal} $script <cookie-file>
${orange}Available options:${normal}
  -h --help Show this help message and exit
_HELP_
  exit "$errcode"
}

create_cookie_file() {
  local cookiefile="$1"
  local -r fortunes_d="/usr/share/games/fortunes"
  sudo_login 2
  printf "Creating %s.dat...\n" "$cookiefile"
  if strfile -c % "$cookiefile" "$cookiefile.dat"; then
    sudo cp "$cookiefile" "$cookiefile.dat" "$fortunes_d"/
    printf "Fortune cookie file created and copied to /%s\n" "$fortunes_d"
    return 0
  else
    printf "Fortune cookie operation failed.\n"
    return 1
  fi
}

main() {
  local script="${0##*/}"
  local version="2.2.26184"
  exit_code=0
  if [[ "$#" -eq 0 ]]; then
    printf "%s No argument passed." >&2 "$RED_ERROR"
    help "$script" "$version" "$E_MISSING_ARG"
  elif [[ "$1" = "-h" || "$1" = "--help" ]]; then
    help "$script" "$version" 0
  else
    local cookiefile="$1"
    [[ -f "$cookiefile" ]] || { printf "%s %s not found.\n" "$RED_ERROR" "$cookiefile" >&2; help "$script" "$version" "$E_FILENOTFOUND"; }
    check_package fortune-mod
    create_cookie_file "$cookiefile"
    exit_code="$?"
	  over_line "$script $version"
	  exit "$exit_code"
  fi
}

## Execution ##

main "$@"

## Source function library ##
# shellcheck source=/home/rick/bin/functionlib
source ~/bin/functionlib || { printf "\e[91mERROR:\e[0m Unable to source functionlib\n"; exit 1; }

## Global Variables ##

readonly i3_dir=~/.config/i3
readonly bindings="bindings.list"

## Functions ##

copy_bindings() {
	local repository
	repository=$(assign_cfg_repo)
	printf "Copying i3 keyboard bindings...\n"
	cp -v "$repository/$bindings" "$i3_dir/$bindings"
}

show_bindings() {
	[[ -f "$i3_dir/$bindings" ]] || copy_bindings
	printf "i3wm keybindings:\n"
	column -t -s "|" -N Binding,Action,Binding,Action "$i3_dir/$bindings"
}

main() {
	local -r script="${0##*/}"
	local -r version="1.10.26173"
	if [[ "$DESKTOP_SESSION" == "i3" ]]; then
		clearscreen
		show_bindings
	else
		printf "i3wm is not the current desktop session.\n"
	fi
	over_line "$script $version"
	exit
}

## Execution ##

main "$@"

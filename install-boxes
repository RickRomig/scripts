## Load function library ##
# shellcheck source=/home/rick/bin/functionlib
source ~/bin/functionlib || { printf "\e[91mERROR:\e[0m Unable to source functionlib\n"; exit 1; }

## Global Variables ##

readonly script="${0##*/}"
readonly version="4.2.26170"
readonly E_BIOS_SETTING=100
EC=0

## Functions ##

help() {
	local errcode="${1:-1}"
	local updated="19 Jun 2026"
	cat << _HELP_
${orange}$script${normal} $version, Upated: $updated
Install Gnome Boxes from either distribution repositories or flatpak from Flathub.

${green}Usage:${normal} $script [-dfh]
${orange}Available options:${normal}
	-d	Install Gnome Boxes from distro repo
	-f	Install Gnome Boxes from Flathub
	-h	Show this help message and exit
_HELP_
  exit "$errcode"
}

boxes_version() {
  if installed gnome-boxes; then
    gnome-boxes --version
  elif grep -qi 'Gnome-Boxes' < <(flatpak list); then
    awk '/Gnome-Boxes/ {print "$NF-2"}' 'gnome-boxes' < <(flatpak list)
  fi
}

check_bios() {
  local vcpu vmx_svm
  local -r qemu_sys_conf="/etc/modprobe.d/qemu-system-x86.conf"
  printf "Checking if virtualization is enabled in BIOS...\n"
  vcpu=$(grep -Ec 'vmx|svm' /proc/cpuinfo)
  printf "Virtualization is "
  if [[ $vcpu -eq 0 ]]; then
    printf "not enabled in the BIOS.\n" >&2
    printf "Enable virtualization before installing Gnome Boxes.\n" >&2
    EC="$E_BIOS_SETTING"
    return
  fi
  printf "enabled in the BIOS. (%d threads)\n" "$vcpu"
  vmx_svm=$(grep -E -m 1 'vmx|svm' /proc/cpuinfo )
  case "$vmx_svm" in
    *vmx* )
      # echo "options kvm_intel nested=1" | sudo tee -a "$qemu_sys_conf" >/dev/null ;;
      sudo tee -a "$qemu_sys_conf" >/dev/null <<< "options kvm_intel nested=1" ;;
    *svm* )
      # echo "options kvm_amd nested=1" | sudo tee -a "$qemu_sys_conf" >/dev/null ;;
      sudo tee -a "$qemu_sys_conf" >/dev/null <<< "options kvm_amd nested=1"
  esac
  sudo tee -a "$qemu_sys_conf" >/dev/null <<< "group=kvm"
}

enable_libvirtd() {
  sudo systemctl enable libvirtd.service
  sudo systemctl start libvirtd.service
  printf "libvirtd started.\n"
}

add_to_kvm_group() {
  local user in_kvm_grp
  grep kvm /etc/group &>/dev/null || sudo groupadd --system kvm
  user=$(whoami)
  in_kvm_grp=$(awk '/kvm:/ && /'"$user"'/' /etc/group)
  printf "User %s " "$user"
  if [[ "$in_kvm_grp" ]]; then
    printf "is already a member of "
  else
    sudo usermod -a -G kvm "$user"
    printf "added to "
  fi
  printf "the kvm group.\n"
  # if [[ -f /etc/libvirt/qemu.conf ]]; then
  #   printf "Allow users in the kvm group to start VMs.\n"
  #   sudo sed -i.bak 's/\#group\ =\ "root"/group\ =\ "kvm"/' /etc/libvirt/qemu.conf
  # else
  #   printf "/etc/libvirt/qemu.conf not found!\n" >&2
  # fi
}

add_to_libvirt_group() {
  local user in_libvirt_grp
  grep libvirt /etc/group &>/dev/null || sudo groupadd --system libvirt
  user=$(whoami)
  in_libvirt_grp=$(awk '/libvirt/ && /'"$user"'/' /etc/group)
  printf "User %s " "$user"
  if [[ "$in_libvirt_grp" ]]; then
    printf "is already a member of "
  else
    sudo usermod -a -G libvirt "$user"
    printf "added to "
  fi
  printf "the libvirt group.\n"
}

link_data_drive() {
  [[ -d /data ]] || return
  [[ -d /data/gnome-boxes ]] || mkdir -p /data/gnome-boxes
  # [[ -d ~/.local/share/gnome-boxes ]] && mv ~/.local/share/gnome-boxes /data/
  ln -vs /data/gnome-boxes ~/.local/share/gnome-boxes
  printf "Gnome-boxes images linked to data drive.\n"
}

install_from_deb() {
  [[ EC -ne 0 ]] && return
  printf "\nInstalling GNOME Boxes (distro)...\n"
  sudo apt update -qq
  sudo apt install -yy gnome-boxes
  sudo apt install qemu-kvm libvirt-daemon-system libvirt-clients bridge-utils virt-manager
  sudo modprobe kvm
  if [[ $(awk '/Vendor ID:/ {print $NF}' < <(lscpu)) == "GueuineIntel" ]]; then
    sudo modprobe kvm_intel
  else
    sudo modprobe kvm_amd
  fi
  if ! installed gnome-boxes; then
    printf "%s Gnome-boxes installation failed.\n" "$RED_ERROR" >&2
    EC="$E_INSTALLATION"
    return
  fi
  printf "Gnome-boxes installed.\n"
  add_to_kvm_group
  add_to_libvirt_group
  enable_libvirtd
  link_data_drive
}

install_from_flatpak() {
  [[ EC -ne 0 ]] && return
  printf "\nInstalling GNOME Boxes (flatpak)...\n"
  flatpak install --user flathub org.gnome.Boxes
  if ! grep -qi 'boxes' < <(flatpak list); then
    printf "%s Gnome-boxes installation failed.\n" "$RED_ERROR" >&2
    EC="$E_INSTALLATION"
    return
  fi
  printf "Gnome-Boxes installed.\n"
  add_to_kvm_group
  enable_libvirtd
  link_data_drive   # I haven't looked into moving or linking to a separate drive
}

main() {
  local noOpt opt optstr OPTARG OPTIND
	noOpt=1
	optstr=":dfh"
	while getopts "$optstr" opt; do
    case "$opt" in
      d )
        if installed gnome-boxes || grep -qi 'boxes' < <(flatpak list); then
          printf "Gnome-Boxes is already installed (Version: %s).\n" "$(boxes_version)"
        else
          sudo_login 2
          check_bios
          install_from_deb
        fi
        ;;
      f )
        if installed gnome-boxes || grep -qi 'boxes' < <(flatpak list); then
          printf "Gnome-Boxes is already installed (Version: %s).\n" "$(boxes_version)"
        else
          sudo_login 2
          check_bios
          install_from_flatpak
        fi
        ;;
      h )
        help 0
        ;;
			? )
				printf "%s Invalid option -%s\n" "$RED_ERROR" "$OPTARG" >&2
        help "$E_INVALID_ARG"
    esac
    noOpt=0
  done
	[[ $noOpt -eq 1 ]] && { printf "%s No argument passed.\n" "$RED_ERROR" >&2; help "$E_MISSING_ARG"; }
	shift "$(( OPTIND - 1 ))"
  # [[ $EC -eq 0 ]] && printf "Gnome boxes installed and configured.\n"
  over_line "$script $version"
  exit "$EC"
}

## Execution ##

main "$@"

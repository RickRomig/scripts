## Source function library ##
# shellcheck source=/home/rick/bin/functionlib
source ~/bin/functionlib || { printf "\e[91mERROR:\e[0m Unable to source functionlib\n"; exit 1; }

# readonly gh_url="https://github.com/micro-editor/micro/releases"

help() {
	local -r script="$1"
	local -r version="$2"
	local -r errcode="${3:-1}"
	local -r updated="11 Jul 2026"
	cat << _HELP_
${orange}$script${normal} $version ($updated)
Installs, configures, updates, or removes the Micro CLI text editor.

${green}Usage:${normal} $script [-hiru]
${orange}Available options:${normal}
  -c  Apply settings and bindings.
  -h  Show this help message and exit.
  -i  Installs the Micro CLI text editor.
  -r  Removes the Micro CLI text editor from the system.
  -u  Updates the Micro CLI text editor to the latest GitHub release.
_HELP_
  exit "$errcode"
}

# shellcheck disable=SC2317 # Don't warn about unreachable commands in this function
# ShellCheck may incorrectly believe that code is unreachable if it's invoked by variable name or in a trap.
cleanup() {
  [[ -d "$TMP_DIR" ]] && rm -rf "$TMP_DIR"
  [[ -f "$TMP_FILE" ]] && rm -f "$TMP_FILE"
}

micro_version() {
  awk '/Version:/ {print $NF}' < <(micro -version)
  return 0
}

convert_compare() {
  local -r newVer="$1"
  local -r curVer="$2"
  local newer="$FALSE"
	local new_arr=()
	local cur_arr=()
  local -i index
	IFS="." read -ra new_arr <<< "$newVer"
	IFS="." read -ra cur_arr <<< "$curVer"
	for (( index=0; index <=2; index++)) ; do
		if [[ "${new_arr[index]}" > "${cur_arr[index]}" ]]; then
      newer="$TRUE"
      break
    fi
	done
	return "$newer"
}

newest_version() {
  local -r gh_url="$1"
  wget -qO "$TMP_FILE" "$gh_url"
  new_ver=$(sed 's/^v//' < <(awk -F'/' '/download/ && /linux/ {print $6;exit}' "$TMP_FILE"))
  echo "$new_ver"
  return 0
}

compare_versions() {
  local -r new_ver="$1"
  local -r gh_url="$2"
  local cur_ver
  cur_ver=$(micro_version)
  printf "Comparing current and newest versions...\n"
  if [[ -z "$new_ver" ]]; then
    printf "%s No download available. Try again later." "$RED_ERROR" >&2
    return "$E_DOWNLOAD"
  elif convert_compare "$new_ver" "$cur_ver"; then
    printf "%sInstalled version of Micro is %s, updating to %s...%s\n" "$lightyellow" "$cur_ver" "$new_ver" "$normal"
    install_micro "$new_ver" "$gh_url"
    return "$?"
  else
    printf "%sMicro %s is the current version. No update required.%s\n" "$lightyellow" "$cur_ver" "$normal"
  fi
  return 0
}

install_micro() {
  local -r new_ver="$1"
  local -r gh_url="$2"
  local new_pkg="micro-${new_ver}-linux64.tar.gz"
  if [[ -z "$new_ver" ]]; then
    printf "%s No download available. Try again later." "$RED_ERROR" >&2
    return "$E_DOWNLOAD"
  fi
  sudo_login 2
  # if the repo verssion is installed, remove it.
  installed micro && sudo apt-get remove micro
  [[ -d /usr/share/micro/ ]] || sudo mkdir /usr/share/micro/
  [[ -d /usr/share/doc/micro/ ]] || sudo mkdir /usr/share/doc/micro/
  printf "Downloading Micro %s from the zyedidia GitHub repository..." "$new_ver"
  wget -q -P "$TMP_DIR/" "$gh_url/download/v$new_ver/$new_pkg"
  printf "Installing Micro %s...\n" "$new_ver"
  tar -xzvf "$TMP_DIR/$new_pkg" -C "$TMP_DIR/"
  sudo cp -v "$TMP_DIR/micro-$new_ver"/micro /usr/bin/
  sudo cp -v "$TMP_DIR/micro-$new_ver"/micro.1 /usr/share/man/man1/
  sudo cp -v "$TMP_DIR/micro-$new_ver"/micro.desktop /usr/share/applications/
  sudo cp -v "$TMP_DIR/micro-$new_ver"/micro.svg /usr/share/micro/
  sudo cp -v "$TMP_DIR/micro-$new_ver"/README.md /usr/share/doc/micro/
  sudo cp -v "$TMP_DIR/micro-$new_ver"/LICENSE* /usr/share/doc/micro/
  installed xclip || sudo apt-get install -y xclip
  if [[ "$(micro_version)" != "$new_ver" ]]; then
    printf "%s Micro installation failed.\n" "$RED_ERROR" >&2
    return "$E_INSTALLATION"
	fi
  printf "Micro %s installed.\n" "$(micro_version)"
  return 0
}

remove_micro() {
  sudo_login 2
  printf "Removing the Micro CLI text editor...\n"
  [[ -L  ~/.config/micro/settings.json ]] && unlink ~/.config/micro/settings.json
  [[ -L  ~/.config/micro/bindings.json ]] && unlink ~/.config/micro/bindings.json
  find ~/.config -type d -name micro -exec rm -rf {} \;
  sudo rm -v /usr/bin/micro
  sudo rm -rfv /usr/share/doc/micro
  sudo find /usr/share -type f -name "micro." -exec rm -f {} ;\
  printf "Micro and configuration files have been removed.\n"
  return 0
}

micro_configs() {
  printf "Applying Micro settings and bindings...\n"
  [[ -d  ~/.config/micro ]] || mkdir -p  ~/.config/micro
	if [[ ! -d ~/Downloads/configs && ! -d ~/gitea/configs ]]; then
		printf "%s Cloned repository not found!\n" "$RED_WARNING" >&2
		return "$E_FILENOTFOUND"
	fi
  [[ -f  ~/.config/micro/settings.json ]] && rm ~/.config/micro/settings.json
  [[ -f ~/.config/micro/bindings.json ]] && rm  ~/.config/micro/bindings.json
  if [[ -d ~/gitea/configs ]]; then
    ln -sv ~/gitea/configs/micro/settings.json  ~/.config/micro/settings.json
    ln -sv ~/gitea/configs/micro/bindings.json  ~/.config/micro/bindings.json
  elif [[ -d ~/Downloads/configs ]]; then
    ln -sv ~/Downloads/configs/micro/settings.json  ~/.config/micro/settings.json
    ln -sv ~/Downloads/configs/micro/bindings.json  ~/.config/micro/bindings.json
  fi
  micro -plugin install bookmark
  printf "Micro setttings applied.\n"
  return 0
}

main() {
  local -r script="${0##*/}"
  locl -r version="8.1.26192"
	local -i exit_code=0
  local -r gh_url="https://github.com/micro-editor/micro/releases"
  local opt new_ver OPTARG OPTIND
  local -i noOpt=1
  local -r optstr=":chiru"
  while getopts "$optstr" opt; do
    case "$opt" in
      c )
        if exists micro; then
          micro_configs
        else
          printf "Micro is not installed.\n" >&2
        fi
        ;;
      h )
        help "$script" "$version" 0
        ;;
      i )
        if exists micro; then
          printf "Micro %s is already installed.\n" "$(micro_version)" >&2
        else
          TMP_FILE=$(mktemp) || die "Failed to create temporary file." "$E_TEMP_FILE"
          TMP_DIR=$(mktemp -d) || die "Failed to create temporary directory." "$E_TEMP_DIR"
          trap cleanup EXIT
          new_ver="$(newest_version "$gh_url")"
          printf "%sInstalling Micro version %s...%s\n" "$lightyellow" "$new_ver" "$normal"
          install_micro "$new_ver" "$gh_url" && micro_configs
        fi
        ;;
      r )
        if exists micro; then
          remove_micro
        else
          printf "Micro is not installed.\n" >&2
        fi
        ;;
      u )
        if exists micro; then
          TMP_FILE=$(mktemp) || die "Failed to create temporary file." "$E_TEMP_FILE"
          TMP_DIR=$(mktemp -d) || die "Failed to create temporary directory." "$E_TEMP_DIR"
          trap cleanup EXIT
          new_ver="$(newest_version "$gh_url")"
          compare_versions "$new_ver" "$gh_url"
        else
          printf "Micro is not installed.\n" >&2
        fi
        ;;
      ? )
				printf "%s Invalid option -%s\n" "$RED_ERROR" "$OPTARG" >&2
        help "$script" "$version" "$E_INVALID_ARG"
    esac
    exit_code="$?"
    noOpt=0
  done
  [[ "$noOpt" = 1 ]] && { printf "%s No argument passed.\n" "$RED_ERROR" >&2; help "$script" "$version" "$E_MISSING_ARG"; }
  shift "$(( OPTIND - 1 ))"
  over_line "$script $version"
  exit "$exit_code"
}

main "$@"

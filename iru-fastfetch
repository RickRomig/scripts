## Source function library ##
# shellcheck source=/home/rick/bin/functionlib.bash
source ~/bin/functionlib.bash || { printf "\e[91mERROR:\e[0m Unable to source functionlib.bash\n"; exit 1; }

help() {
  local -r script="$1"
  local -r version="$2"
	local -r errcode="${3:-1}"
	local -r updated="13 Jul 2026"
	cat << _HELP_
${orange}$script${normal} $version ($updated)
Installs, configures, removes, updates FastFetch

${green}Usage:${normal} $script [-hiru]
${orange}Available options:${normal}
  -h  Show this help message and exit
  -i  Install Fastfetch
  -r  Remove Fastfetch
  -u  Update Fastfetch to the latest GitHub release
_HELP_
  exit "$errcode"
}

# Don't warn about unreachable commands in this function
# ShellCheck may incorrectly believe that code is unreachable if it's invoked by variable name or in a trap.
# shellcheck disable=SC2317
cleanup() {
	[[ -f "$TMP_FILE" ]] && rm "$TMP_FILE"
	[[ -d "$TMP_DIR" ]] && rm -rf "$TMP_DIR"
}

ff_version() {
	fastfetch --version-raw
  return 0
}

convert_compare() {
  local -r newVer="$1"
  local -r curVer="$2"
  local newer="$FALSE"
	local new_arr=()
	local cur_arr=()
  local -i index
	IFS="." read -ra new_arr <<< "$newVer"
	IFS="." read -ra cur_arr <<< "$curVer"
	for (( index=0; index <=2; index++)) ; do
		if [[ "${new_arr[index]}" > "${cur_arr[index]}" ]]; then
      newer="$TRUE"
      break
    fi
	done
	return "$newer"
}

newest_version() {
	local new_ver
  wget -qO "$TMP_FILE" "$gh_url"
  new_ver=$(awk -F'/' '/download/ && /.deb/ {print $6}' "$TMP_FILE")
  echo "$new_ver"
  return 0
}

compare_versions() {
	local -r new_ver="$1"
  local -r gh_url="$2"
	local cur_ver
  cur_ver="$(ff_version)"
	printf "Comparing current and newest versions...\n"
  if [[ -z "$new_ver" ]]; then
    printf "%s No download available. Try again later." "$RED_ERROR" >&2
    return "$E_DOWNLOAD"
  elif convert_compare "$new_ver" "$cur_ver"; then
    printf "%sInstalled version of FastFetch is %s, updating to %s...%s\n" "$lightyellow" "$cur_ver" "$new_ver" "$normal"
		install_fastfetch "$new_ver" "$gh_url"
    return "$?"
  else
    printf "%s FastFetch %s is the current version. No update required.%s\n" "$lightyellow" "$cur_ver" "$normal"
	fi
  return 0
}

install_fastfetch(){
	local -r new_ver="$1"
	local -r gh_url="$2"
	local -r new_pkg="fastfetch-linux-amd64.deb"
  if [[ -z "$new_ver" ]]; then
    printf "%s No download available. Try again later." "$RED_ERROR" >&2
    return "$E_DOWNLOAD"
  fi
	sudo_login 2
  printf "Downloading FastFetch %s from the fastfetch-cli GitHub repository..." "$new_ver"
  dots "." &
	DOTS_PID="$!"
  wget -q -P "$TMP_DIR/" "$gh_url/download/$new_ver/$new_pkg"
	kill_dots
  printf "Installing FastFetch %s...\n" "$new_ver"
	sudo dpkg -i "$TMP_DIR/$new_pkg"; sudo apt-get install --fix-broken
  if [[ "$(ff_version)" != "$new_ver" ]]; then
    printf "%s Fastfetch installation failed.\n" "$RED_ERROR" >&2
    return "$E_INSTALLATION"
	fi
  printf "%sFastFetch %s installed.%s\n" "$lightyellow" "$(ff_version)" "$normal"
	return 0
}

remove_fastfetch() {
	sudo_login 2
	printf "Removing FastFetch %s ...\n" "$(ff_version)"
	sudo dpkg --purge fastfetch
	find ~/ -maxdepth 3 -type d -path "$HOME/Downloads" -prune -o -path "$HOME/gitea" -prune -o -type d -name fastfetch -exec rm -rf {} \;
	find /usr/share -type f,d -iname "fastfetch*" -exec sudo rm -rf {} \;
	printf "Fastfetch and its configuration files have been removed.\n"
}

fastfetch_config() {
	local repository=~/Downloads/configs/fastfetch
	[[ -d ~/gitea/configs/fastfetch ]] && repository=~/gitea/configs/fastfetch
	if [[ ! -d "$repository" ]]; then
    printf "%s Cloned repository not found!\n" "$RED_WARNING" >&2
		return "$E_FILENOTFOUND"
  fi
	[[ -d ~/.config/fastfetch ]] || mkdir -p ~/.config/fastfetch
	[[ -d ~/.local/share/fastfetch/logos ]] || mkdir -p ~/.local/share/fastfetch/logos
	printf "Installing configuration and logo files...\n"
	if grep -q -E 'GM965|GL960' <(lspci); then
		cp -v "$repository"/config.jsonc.ascii ~/.config/fastfetch/config.jsonc
		cp -v /logo.txt ~/.local/share/fastfetch/logos/
	else
		cp -v "$repository"/config.jsonc ~/.config/fastfetch/
		cp -v "$repository"/logo.png ~/.local/share/fastfetch/logos/
	fi
	grep -qw gigi < <(lsb_release -cs) && sed -i '/type/s/kitty-direct/kitty/' ~/.config/fastfetch/config.jsonc
	printf "Fastfetch configuration applied.\n"
	return 0
}

main() {
	local -r script="${0##*/}"
	local -r  version="4.6.26201"
	local -i exit_code=0
	local -r gh_url="https://github.com/fastfetch-cli/fastfetch/releases"
  local opt new_ver OPTARG OPTIND
	local -i noOpt=1
	local -r optstr=":hiru"
	while getopts "$optstr" opt; do
		case "$opt" in
			h )
				help "$script" "$version" 0
				;;
			i )
				if installed fastfetch; then
					printf "Fastfetch %s is already installed.\n" "$(ff_version)" >&2
				else
					check_package wget
					TMP_FILE=$(mktemp) || die "Failed to create temporary file." "$E_TEMP_FILE"
					TMP_DIR=$(mktemp -d) || die "Failed to create temporary directory." "$E_TEMP_DIR"
					trap cleanup EXIT
					new_ver="$(newest_version "$gh_url")"
					printf "%sInstalling Fastfetch version %s...%s\n" "$lightyellow" "$new_ver" "$normal"
					install_fastfetch "$new_ver" "$gh_url" && fastfetch_config
				fi
				;;
			r )
				if installed fastfetch; then
					remove_fastfetch
				else
					printf "Fastfetch is not installed.\n" >&2
				fi
				;;
			u )
				if installed fastfetch; then
					check_package wget
					TMP_FILE=$(mktemp) || die "Failed to create temporary file." "$E_TEMP_FILE"
          TMP_DIR=$(mktemp -d) || die "Failed to create temporary directory." "$E_TEMP_DIR"
					trap cleanup EXIT
					new_ver="$(newest_version "$gh_url")"
					compare_versions "$new_ver" "$gh_url"
				else
					printf "Fastfetch is not installed.\n" >&2
				fi
				;;
			? )
				printf "%s Invalid option -%s\n" "$RED_ERROR" "$OPTARG" >&2
				help "$script" "$version" "$E_INVALID_ARG"
		esac
		exit_code="$?"
		noOpt=0
	done
	[[ "$noOpt" = 1 ]] && { printf "%s No argument passed.\n" "$RED_ERROR" >&2; help "$script" "$version" "$E_MISSING_ARG"; }
	shift "$(( OPTIND - 1 ))"
	over_line "$script $version"
	exit "$exit_code"
}

## Execution ##

main "$@"

## Source function library ##
# shellcheck source=/home/rick/bin/functionlib
source ~/bin/functionlib || { printf "\e[91mERROR:\e[0m Unable to source functionlib\n"; exit 1; }

CALENDAR=$(mktemp -q) || die "Failed to create temporary file." "$E_TEMP_FILE"

# shellcheck disable=SC2317 # Don't warn about unreachable commands in this function
# ShellCheck may incorrectly believe that code is unreachable if it's invoked by variable name or in a trap.
cleanup() {
	[[ -f "$CALENDAR" ]] && rm -f "$CALENDAR"
}

help() {
	local -r script="$1"
	local -r version="$2"
	local -r errcode="${3:-1}"
	local -r updated="09 Jul 2026"
	cat <<- _HELP_
${orange}$script${normal} $version, Updated: $updated
Creates/displays/edits a simple to-do list with a calendar.

${green}Usage:${normal} $script [-e13h]
${orange}Available options:${normal}
	-1  Display current month calendar and to-do list.
	-3  Display 3-month calendar and to-do list.
	-e  Edit/create to-do list.
	-h  Show this help message and exit.
	NOTE: To-do list should be limited to 7 short items to maintain format.
_HELP_
	exit "$errcode"
}

create_todo() {
	local -r doc_dir="$1"
	local -r todolist="$2"
	local script_dir
	script_dir=$(dirname "$(readlink -f "${0}")")
	[[ -d "$doc_dir" ]] || mkdir -p "$doc_dir"
	printf "Creating todo list...\n"
	cp -v "$script_dir/Templates/$todolist" "$doc_dir/"
	$EDITOR "$doc_dir/$todolist"
	return "$?"
}

print_months() {
	local previous current next
	local -i padding=6
	printf -v previous "%*s%s%*s" "$padding" "" "$(date -d "$(date +%F) - 1 month" +'%b %Y')" "$padding" ""
	printf -v current "%*s%s%*s" "$padding" "" "$(date +'%b %Y')" "$padding" ""
	printf -v next "%*s%s%*s" "$padding" "" "$(date -d "$(date +%F) + 1 month" +'%b %Y')" "$padding" ""
	printf "\n%s  %s  %s\n" "$previous" "$current" "$next"
	return 0
}

show_one_month() {
	local -r doc_dir="$1"
	local -r todolist="$2"
	clear
	cal > "$CALENDAR"
	paste "$CALENDAR" "$doc_dir/$todolist"
	return "$?"
}

show_three_months() {
	local -r doc_dir="$1"
	local -r todolist="$2"
	clear
	print_months
	sed '1d' < <(cal -3) > "$CALENDAR"	# strips off the year (1st line) to line up todo list with the month.
	paste "$CALENDAR" "$doc_dir/$todolist"
	return "$?"
}

main() {
	local -r script="${0##*/}"
	local -r version="3.9.26190"
	local -i exit_code=0
	local opt OPTARG OPTIND
	local -r doc_dir=~/.local/share/doc
	local -r todolist="todo.lst"
	local -i noOpt=1
	local -r optstr=":13eh"
	trap cleanup EXIT
	check_package ncal
	while getopts "$optstr" opt; do
		case "$opt" in
			1 )
				[[ -f "$doc_dir/$todolist" ]] || create_todo "$doc_dir" "$todolist"
				show_one_month "$doc_dir" "$todolist"
				;;
			3 )
				[[ -f "$doc_dir/$todolist" ]] || create_todo "$doc_dir" "$todolist"
				show_three_months "$doc_dir" "$todolist"
				;;
			e )
				if [[ -f "$doc_dir/$todolist" ]]; then
					$EDITOR "$doc_dir/$todolist"
					printf "To-Do list edited.\n"
				else
					create_todo "$doc_dir" "$todolist"
					printf "To-Do list created.\n"
				fi
				;;
			h )
				help "$script" "$version" 0
				;;
			? )
				printf "%s Invalid option: -%s\n" >&2 "$RED_ERROR" "$OPTARG"
				help "$script" "$version" "$E_INVALID_ARG"
		esac
		exit_code="$?"
		noOpt=0
	done
	[[ "$noOpt" = 1 ]] && { printf "%s No argument passed.\n" "$RED_ERROR" >&2; help "$script" "$version" "$E_MISSING_ARG"; }
	shift "$(( OPTIND - 1 ))"
	over_line "$script $version"
	exit "$exit_code"
}

main "$@"

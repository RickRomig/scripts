## Source function library ##
# shellcheck source=/home/rick/bin/functionlib
source ~/bin/functionlib || { printf "\e[91mERROR:\e[0m Unable to source functionlib\n"; exit 1; }

help() {
  local -r script="$1"
  local -r version="$2"
	local -r errcode="${3:-1}"
	local -r updated="08 Jul 2026"
	cat << _HELP_
${orange}$script${normal} $version, Upated: $updated
Clone a git repository from GitHub or the local Gitea server

${green}Usage:${normal} $script [-cfghipsw]
${orange}Available options:${normal}
  -c  Clone configs repository
  -f  Clone fnloc repository
  -g  Clone gitea server repository
  -h  Show this help message and exit
  -i  Clone i3wm-debian repository
  -p  Clone homepage repository
  -s  Clone scripts repository
  -w  Clone fnloc-win repository
_HELP_
  exit "$errcode"
}

check_repo() {
  local -r git_repo="$1"
  local -r dl_dir=~/Downloads
  if [[ $(find "$dl_dir/$git_repo" -maxdepth 1 -type f 2>/dev/null) ]]; then
    printf "%s is not empty. Updating the repository clone...\n" "$dl_dir/$git_repo"
    pushd "$dl_dir/$git_repo" || return "$E_POPD_PUSHD"
    git checkout .
    git pull
    popd || return "$E_POPD_PUSHD"
  else
    clone_repo "$git_repo" "$dl_dir/"
  fi
  return "$?"
}

clone_repo() {
  local git_repo="$1"
  local dl_dir="$2"
  local url
  case "$git_repo" in
    configs | scripts | i3wm-debian )
      url="$GITHUB_URL" ;;
    * )
      url="$GITEA_URL"
  esac
  git clone "$url/${git_repo}.git" "$dl_dir/$git_repo"
  return "$?"
}

main() {
  local -r script="${0##*/}"
  local -r version="5.2.26189"
  local exit_code=0
  local opt OPTARG OPTIND
  local -i noOpt=1
  local -r optstr=":cfghilsw"
  check_package git
  while getopts "$optstr" opt; do
    case "$opt" in
      c ) check_repo "configs" ;;
      f ) check_repo "fnloc" ;;
      g ) check_repo "gitea-server" ;;
      h ) help "$script" "$version" 0 ;;
      i ) check_repo "i3wm-debian" ;;
      p ) check_repo "homepage" ;;
      s ) check_repo "scripts" ;;
      w ) check_repo "fnloc-win" ;;
			? ) printf "%s Invalid option -%s\n" "$RED_ERROR" "$OPTARG" >&2; help "$script" "$version" "$E_INVALID_ARG"
    esac
    exit_code="$?"
		noOpt=0
  done
	[[ "$noOpt" = 1 ]] && { printf "%s No argument passed.\n" "$RED_ERROR" >&2; help "$script" "$version" "$E_MISSING_ARG"; }
	shift "$(( OPTIND - 1 ))"
	over_line "$script $version"
	exit "$exit_code"
}

main "$@"

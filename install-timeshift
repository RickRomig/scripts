## Load function library ##
# shellcheck source=/home/rick/bin/functionlib
source ~/bin/functionlib || { printf "\e[91mERROR:\e[0m Unable to source functionlib\n"; exit 1; }

## Functions ##

get_snapshot_uuid() {
  local target_uuid
  target_uuid=$(awk '/data/ {print $(NF-3)}' < <(lsblk -f))  if /data partition exists
  [[ "$target_uuid" ]] || target_uuid=$(awk '/home/ {print $(NF-3)}' < <(lsblk -f)) # home partition if no /data partition
  [[ "$target_uuid" ]] || target_uuid=$(awk '/\/$/ {print $NF-3}' < <(lsblk -f))  # root partition if no /home partition
  printf "%s" "$target_uuid"
}

configure_timeshift() {
  local ts_uuid script_dir
  ts_uuid=$(get_snapshot_uuid)
  script_dir=$(dirname "$(readlink -f "${0}")")
  local -r ts_dir="/etc/timeshift"
  local -r ts_json="timeshift.json"
  local -r ts_sed="$script_dir/files/timeshift.sed"
  if [[ ! -f "$ts_sed" ]]; then
    printf "%s was not found. Configure using the GUI application.\n"  "${ts_sed##*/}" >&2
    EC="$E_FILENOTFOUND"
    return
  fi
  printf "Configuring Timeshift...\n"
  sudo cp -v "$ts_dir/default.json" "$ts_dir/$ts_json"  # copy default json file
  sudo sed -i -f "$ts_sed" "$ts_dir/$ts_json" # configure settings
  sudo sed -i "/backup_device_uuid/ s/\",/$ts_uuid\",/" "$ts_dir/$ts_json"  # insert UUID for snapshots
  sudo sed -i 's/^"\//    "\//;s/^"/  "/' "$ts_dir/$ts_json"  # adjust leading spaces in json file
  printf "Timeshift configured.\n"
}

install_timeshift() {
  sudo_login 2
  printf "Installing Timeshift...\n"
  sudo apt-get install -y timeshift
  if ! installed timeshift; then
    printf "Timeshift installation failed." >&2
    EC="$E_INSTALLATION"
    return
  fi
  printf "Timeshift %s installed.\n" "$(timeshift --version)"
  configure_timeshift
}

main() {
  local -r script="${0##*/}"
  local -r version="3.6.26146"
  EC=0
  if installed timeeshift; then
    printf "%s is already installed.\n" "$(timeshift --version)"
  else
    install_timeshift
  fi
  over_line "$script $version"
  exit "$EC"
}

## Execution ##

main "$@"

## Source function library ##
# shellcheck source=/home/rick/bin/functionlib
source ~/bin/functionlib || { printf "\e[91mERROR:\e[0m Unable to source functionlib\n"; exit 1; }

help() {
	local -r script="$1"
	local -r version="$2"
	local -r errcode="${3:-1}"
	local -r updated="09 Jul 2026"
	cat << _HELP_
${orange}$script${normal} $version, Updated: $updated
Installs/removes/configures bat/batcat

${green}Usage:${normal} $script [-chir]

${orange}Available options:${normal}
  -c	Install bat configuration file.
  -h	Show this help message and exit.
  -i	Install bat from Debian/Ubuntu repository.
  -r	Remove bat and configuration files.
_HELP_
  exit "$errcode"
}

bat_version() {
  awk '/^ii/ {print $3}' < <(dpkg -l bat)
	return 0
}

install_batcat() {
	sudo_login 2
	sudo apt-get install -yy bat
	if ! exists batcat; then
		printf "%s Batcat failed to install."  "$RED_ERROR" >&2
		return "$E_INSTALLATION"
	fi
	printf "Bat (Batcat) version %s installed.\n" "$(bat_version)"
	bat_config
	return 0
}

remove_batcat() {
	sudo_login 2
  printf "Removing Bat %s...\n" "$(bat_version)"
	[[ -L ~/.local/bin/bat ]] && unlink ~/.local/bin/bat
	sudo apt-get remove --purge -y bat
	if default_no "Remove configuration files?"; then
		[[ -L ~/.config/bat/config ]] && unlink ~/.config/bat/config
		find ~/.config -type d -name bat -exec rm -rf {} \;
		printf "Bat configuration files removed.\n"
	else
		printf "User configuration files retained.\n"
	fi
  printf "Batcat has been removed.\n"
	return 0
}

bat_config() {
	[[ -d ~/.config/bat ]] || mkdir -p ~/.config/bat
	if [[ ! -d ~/Downloads/configs && ! -d ~/gitea/configs ]]; then
		printf "%s Cloned repository not found!\n" "$RED_WARNING" >&2
		return "$E_FILENOTFOUND"
	fi
  printf "Applying Bat configuration...\n"
	[[ -f ~/.config/bat/config ]] && rm ~/.config/bat/config
	[[ -d ~/gitea/configs ]] && ln -sv ~/gitea/configs/bat/config ~/.config/bat/config
	[[ -d ~/Downloads/configs ]] && ln -sv ~/Downloads/configs/bat/config ~/.config/bat/config
	if [[ -f /usr/bin/batcat ]]; then
		[[ -d ~/.local/bin ]] || mkkdir -p ~/.local/bin
		ln -sv /usr/bin/batcat ~/.local/bin/bat
	fi
  printf "Bat configuration applied.\n"
	return 0
}

main() {
	local -r script="${0##*/}"
	local -r version="2.14.26190"
	local -i exit_code=0
	local opt OPTARG OPTIND
	local -i noOpt=1
	local -r optstr=":chir"
	while getopts "$optstr" opt; do
		case "$opt" in
			c )
				if installed bat; then
					bat_config
				else
					printf "Bat (Batcat) is not installed.\n"
				fi
				;;
			h )
				help "$script" "$version" 0
				;;
			i )
				if installed bat; then
					printf "Bat (Batcat) %s is already installed.\n" "$(bat_version)"
				else
					install_batcat
				fi
				;;
			r )
				if installed bat; then
					printf "Bat (Batcat) is not installed.\n"
				else
					remove_batcat
				fi
				;;
			? )
				printf "%s Invalid option -%s\n" "$RED_ERROR" "$OPTARG" >&2
				help "$script" "$version" "$E_INVALID_ARG"
		esac
		exit_code="$?"
		noOpt=0
	done
	[[ "$noOpt" = 1 ]] && { printf "%s No argument passed.\n" "$RED_ERROR" >&2; help "$script" "$version" "$E_MISSING_ARG"; }
	shift "$(( OPTIND - 1 ))"
	over_line "$script $version"
	exit "$exit_code"
}

main "$@"

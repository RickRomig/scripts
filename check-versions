## Load function library ##
# shellcheck source=/home/rick/bin/functionlib
source functionlib || { printf "\e[91mERROR:\e[0m Unable to source functionlib\n"; exit 1; }

## Global Variables ##

TMP_FILE=$(mktemp -q) || die "Failed to create temporary file." "$E_TEMP_FILE"

## Functions ##

# shellcheck disable=SC2317
# Don't warn about unreachable commands in this function
# ShellCheck may incorrectly believe that code is unreachable if it's invoked by variable name or in a trap.
cleanup() {
	[[ -f "$TMP_FILE" ]] && rm -f "$TMP_FILE"
}

installed_version() {
  local package="$1"
  local cur_ver
  case "$package" in
    dsh )
      cur_ver=$(awk 'NR==1 {print $NF}' <(dsh --version 2>/dev/null)) ;;
    firefox )
      cur_ver=$(cut -d' ' -f3 <(firefox --version 2>/dev/null)) ;;
    fresh-editor )
      cur_ver=$(awk '/^ii/ {print $3}' <(dpkg -l "$package" 2>/dev/null) | sed 's/[-~+ud].*//') ;;
    gitea )
      cur_ver=$(cut -d' ' -f3 <(gitea --version 2>/dev/null)) ;;
    micro )
      cur_ver=$(awk '/Version:/ {print $NF}' <(micro -version 2>/dev/null)) ;;
    * )
      cur_ver=$(awk '/^ii/ {print $3}' <(dpkg -l "$package" 2>/dev/null) | sed 's/[~+ud].*//')
  esac
  echo "$cur_ver"
}

show_versions() {
	local package packages
	packages=("$@")
	for package in "${packages[@]}"; do
		if exists "$package"; then
			printf "%s%-15s%s" "${darkgray}" "${package^}" "${gray}"
			[[ "$package" == "batcat" ]] && package="bat"
			[[ "$package" == "google-chrome" ]] && package+="-stable"
      printf "%s\n" "$(installed_version "$package")"
		fi
	done
	printf "%s\n" "$normal"
}

get_release_path() {
	local package="$1"
	declare -rA releases_path=(
		[bat]="sharkdp/bat/releases"
		[codium]="VSCodium/vscodium/releases"
		[fastfetch]="fastfetch-cli/fastfetch/releases"
		[fresh-editor]="sinelaw/fresh/releases"
		[micro]="micro-editor/micro/releases"
	)
	echo "${releases_path[$package]}"
}

get_new_version() {
	local package="$1"
	local release_path="$2"
	local new_ver
	local -r github_url="https://github.com"
  curl -s -o "$TMP_FILE" "$github_url/$release_path"
  # Extract latest version number from temp file, ignoring beta and release candidates.
  case "$package" in
    codium )
      new_ver=$(grep -Ev 'beta|-rc' <(awk -F'/' '/download/ && /amd64.deb/ {print $8;exit}' "$TMP_FILE") | sed 's/^v//') ;;
    micro )
      new_ver=$(grep -Ev 'beta|-rc' <(awk -F'/' '/download/ && /linux/ {print $6;exit}' "$TMP_FILE") | sed 's/^v//') ;;
    fastfetch )
      new_ver=$(awk -F'/' '/download/ && /.deb/ {print $6;exit}' "$TMP_FILE") ;;
    fresh-editor )
      new_ver=$(sed 's/^v//' <(awk -F'/' '/download/ && /x86/ {print $6;exit}' "$TMP_FILE")) ;;
    * )
      new_ver=$(grep -Ev 'beta|-rc' <(awk -F'/' '/download/ && /amd64.deb/ {print $6;exit}' "$TMP_FILE") | sed 's/^v//')
  esac
  echo "$new_ver"
}

github_packages() {
  local cur_ver new_ver package packages release_path
  packages=( bat codium fastfetch fresh-editor micro )
  printf "%-16s%-16s%s\n" "GitHub Package" "Latest version" "Installed version"
  for package in "${packages[@]}"; do
    cur_ver=$(installed_version "$package")
		release_path=$(get_release_path "$package")
    new_ver=$(get_new_version "$package" "$release_path")
    printf "%s%-16s" "${darkgray}" "${package^}"
    if [[ "$new_ver" ]]; then
      printf "%s%-16s" "${gray}" "$new_ver"
     else
      printf "%s%-16s" "${red}" "No release"
    fi
    if [[ ! "$new_ver" > "$cur_ver" ]]; then
      printf "%s%s\n" "${gray}" "$cur_ver"
    elif [[ "$cur_ver" ]]; then
      printf "%s%-16s%sUpdate available\n" "${gray}" "$cur_ver" "${orange}"
    else
      printf "%s%s\n" "${gray}" "not installed"
    fi
  done
  printf "%s\n" "${normal}"
}

utility_packages() {
	local packages package
  packages=( bash dsh flatpak fzf git gitea keepassxc nala picom zoom )
	printf "%-15s%s\n" "Package" "Version"
	show_versions "${packages[@]}"
}

text_editors() {
  local package packages
  packages=( batcat bluefish featherpad geany gedit glow mousepad nano shellcheck xed )
	printf "%-15s%s\n" "Package" "Version"
	show_versions "${packages[@]}"
}

terminals() {
	local packages package
  packages=( gnome-terminal kitty lxterminal terminator xfce4-terminal xterm )
	printf "%-15s%s\n" "Terminal" "Version"
	show_versions "${packages[@]}"
}

browsers() {
	local packages package
  packages=( brave-browser chromium firefox google-chrome librewolf )
	printf "%-15s%s\n" "Browser" "Version"
	show_versions "${packages[@]}"
}

main() {
  local script="${0##*/}"
  local version="20.2.26106"
  trap cleanup EXIT
  check_package curl
  clear
  box "$script $version"
  printf "\n"
  github_packages
  text_editors
  browsers
  terminals
  utility_packages
  leave ""
}

## Execution ##

main "$@"

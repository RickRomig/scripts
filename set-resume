## Source function library ##
# shellcheck source=/home/rick/bin/functionlib
source ~/bin/functionlib || { printf "\e[91mERROR:\e[0m Unable to source functionlib\n"; exit 1; }

## Functions ##

print_message() {
  cat << _MESSAGE_
  Set RESUME environment variable after an update-initramfs error message.
  The error message will be similar to:
  ${lightyellow}I: The initramfs will attempt to resume from /dev/sda2
  I: (UUID=09e25397-4a2c-4fb0-a605-a7013eexit_codeb59c)
  I: Set the RESUME variable to override this.${normal}

_MESSAGE_
}

get_swap_uuid() {
  local swap_uuid
  swap_uuid=$(awk -F\" '/swap/ {print $2}' < <(sudo /usr/sbin/blkid))
  [[ "$swap_uuid" == "LABEL=swap" ]] && swap_uuid=$(awk -F\" '/swap/ {print $3}' < <(sudo /usr/sbin/blkid))
  printf "%s" "$swap_uuid"
  return 0
}

set_resume() {
  local swap_uuid
  sudo_login 2
  printf "\nExtracting the swap UUID from /usr/sbin/blkid ...\n"
  swap_uuid=$(get_swap_uuid)
  [[ "$swap_uuid" ]] || { printf "No UUID for swap found.\n" >&2; return 1; }
  if default_no "Set RESUME environment variable?"; then
    local -r resume_path="/etc/initramfs-tools/conf.d/resume"
    printf "\nSWAP UUID: %s\n" "$swap_uuid"
    printf "\nSetting the RESUME environment variable in %s...\n" "$resume_path"
    sudo tee "$resume_path" &>/dev/null <<< "RESUME=UUID=$swap_uuid"
    printf "\nUpdating initramfs ...\n"
    sudo update-initramfs -u -k all
    return "$?"
  else
    printf "Operation canceled. RESUME environment variable not reset.\n"
    return 0
  fi
}

main() {
  local script="${0##*/}"
  local -r version="7.4.26184"
  local exit_code=0
  print_message
  set_resume
  exit_code="$?"
  over_line "$script $version" "-"
  [[ "$exit_code" -eq 0 ]] && reboot_system
  exit "$exit_code"
}

## Exexit_codeution ##

main "$@"

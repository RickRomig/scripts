## Source function library ##
# shellcheck source=/home/rick/bin/functionlib
source ~/bin/functionlib || { printf "\e[91mERROR:\e[0m Unable to source functionlib\n"; exit 1; }

## Global Variables ##

license_file=
license_type=

## Functions ##

help() {
  local -r script="$1"
  local -r version="$2"
  local errcode="${3:-1}"
  local updated="06 Jul 2026"
  cat << _HELP_
${orange}$script${normal} $version ($updated)
Inserts an Open Source license into a shell script or a C/C++ source code file.

${green}Usage:${normal} $script [-h] [-c c-source-file] [-p cpp-source-file] [-s shell-script]
${orange}Available licenses:${normal}
  -c  C code
      $script -c <c-source.c>
  -h  Show this help message and exit
  -p  C++ code
      $script -p <c-source.cpp>
  -s  Shell script
      $script -s <shell-script>
_HELP_
  exit "$errcode"
}

# shellcheck disable=SC2317 # Don't warn about unreachable commands in this function
# ShellCheck may incorrectly believe that code is unreachable if it's invoked by a variable name or in a trap.
cleanup() {
  [[ -f "$TMP_FILE" ]] && rm -f "$TMP_FILE"
}

check_code_file() {
	local -r codefile="$1"
	if [[ -f "$codefile" ]]; then
		printf "File: %s\n" "$code_file"
		return "$TRUE"
	fi
	printf "%s %s not found\n" "$RED_ERROR" "$codefile" >&2
	return "$FALSE"
}

set_license() {
	local licenses=("GPL v1" "GPL v2" "GPL v3" "MIT")
	printf "\n%sLicense type:%s\n" "$orange" "$normal"
	PS3="Select the type of license: "
	select license_type in "${licenses[@]}"; do
		case $license_type in
			"GPL v1" ) license_file="gpl_v1.txt"; break ;;
			"GPL v2" ) license_file="gpl_v2.txt"; break ;;
			"GPL v3" ) license_file="gpl_v3.txt"; break ;;
			"MIT" ) license_file="mit_lic.txt"; break ;;
			* ) printf "%sInvalid option. Try again.%s\n" "$lightred" "$normal" >&2
		esac
	done
  return 0
}

insert_license() {
	local cur_yr
	local -r code_type="$1"
	local -r code_file="$2"
  cur_yr=$(printf "\UA9 %(%Y)T")
	local -r template_dir=~/bin/Templates
	case $code_type in
		"C" )
			sed -e '1d' \
				-e "s/<YEAR>/$cur_yr/" \
				-e "s/^/ * /" "$template_dir/$license_file" > "$TMP_FILE"
			sed -i -e "21r ${TMP_FILE}" "$code_file"
			;;
		"C++" )
			sed -e '1d' \
				-e "s/<YEAR>/$cur_yr/" \
				-e "s/^/\/\/ /" "$template_dir/$license_file" > "$TMP_FILE"
			sed -i -e "22r ${TMP_FILE}" "$code_file"
			;;
		"Shell" )
			sed -e '1d' \
				-e "s/<YEAR>/$cur_yr/" \
				-e "s/^/# /" "$template_dir/$license_file" > "$TMP_FILE"
			sed -i -e "15r ${TMP_FILE}" "$code_file"
			;;
		* )
			die "Invalid code type. Exiting the script." "$E_INVALID_ARG"		# Should never occur
	esac
	printf "%s license has been inserted into %s.\n" "$license_type" "$code_file"
  return 0
}

main() {
 local -r script="${0##*/}"
  local -r version="4.10.26187"
	local opt code_file code_type OPTARG OPTIND
	local -i noOpt=1
	local -r optstr=":c:hp:s:"
	while getopts "$optstr" opt; do
		case "$opt" in
			c )
				code_file="$OPTARG"
				check_code_file "$code_file" || help "$script" "$version" "$E_FILENOTFOUND"
				code_type="C"
				printf "Code type: %s source code\n" "$code_type"
				;;
			h )
				help 0
				;;
			p )
				code_file="$OPTARG"
				check_code_file "$code_file" || help "$script" "$version" "$E_FILENOTFOUND"
				code_type="C++"
				printf "Code type: %s source code\n" "$code_type"
				;;
			s )
				code_file="$OPTARG"
				check_code_file "$code_file" || help "$script" "$version" "$E_FILENOTFOUND"
				code_type="Shell"
				printf "Code type: %s source code\n" "$code_type"
				;;
			: )
				printf "%s Must supply an argument to -%s.\n" "$RED_ERROR" "$OPTARG" >&2
				help "$script" "$version" "$E_MISSING_ARG"
				;;
			? )
				printf "%s Invalid option -%s\n" "$RED_ERROR" "$OPTARG" >&2
				help "$script" "$version" "$E_INVALID_ARG"
		esac
		noOpt=0
	done
	[[ "$noOpt" = 1 ]] && { printf "%s No argument passed.\n" "$RED_ERROR" >&2; help "$script" "$version" "$E_MISSING_ARG"; }
	shift "$(( OPTIND - 1 ))"
	TMP_FILE=$(mktemp -q) || die "Failed to create temporary file." "$E_TEMP_FILE"
	trap cleanup EXIT
	set_license
	insert_license "$code_type" "$code_file"
	edit_view_quit "$code_file"
	over_line "$script $version"
	printf "MOTD: "; leave ""
}

## Executtion **

main "$@"

## Load function library ##
# shellcheck source=/home/rick/bin/functionlib
source ~/bin/functionlib || { printf "\e[91mERROR:\e[0m Unable to source functionlib\n"; exit 1; }

## Functions ##

check_webcam() {
  if ! grep -iqsw webcam < <(/usr/bin/lsusb); then
    printf "No webcam found.\n"
    return
  fi
  grep -iw webcam < <(/usr/bin/lsusb)
}

main() {
  local -r script="${0##*/}"
  local -r version="4.4.26132"
  check_webcam
  over_line "$script $version" "-"
  exit
}

## Execution ##

main "$@"

## Source function library ##
# shellcheck source=/home/rick/bin/functionlib.bash
source ~/bin/functionlib.bash || { printf "\e[91mERROR:\e[0m Unable to source functionlib.bash\n"; exit 1; }

remove_backup_files() {
	local -r homepage_d="$1"
	local -i num_bu
	num_bu=$(wc -l < <(find "$homepage_d" \( -name "*.bak" -o -regex '\./.*~$' \) -type f -print))
  printf "\n%sRemoving backup files...%s\n" "$lightyellow" "$normal"
	(( num_bu == 0 )) && { printf "No backup files found.\n"; return 0; }
	find "$homepage_d" \( -name "*.bak" -o -regex '\./.*~$' \) -type f -delete
	return 0
}

archive_homepage_repo() {
	local -r archive_d="$1"
	local archive old_archives
	archive="homepage-$(date +%y%m%d).tar.gz"
	old_archives=$(wc -l < <(find "$archive_d" -type f -mtime +90 -print))
	[[ -d "$archive_d" ]] || mkdir -p "$archive_d"
	printf "\n%sArchiving homepage repository...%s\n" "$lightyellow" "$normal"
	tar -czf "$archive_d/$archive" -C "$HOME/gitea" homepage
	printf "Hompage repoisitory archived.\n"
	printf "\n%sRemoving old archives...%s\n" "$lightyellow" "$normal"
	(( old_archives == 0 )) && { printf "No old archives found.\n"; return 0; }
	find "$archive_d" -mtime +90 -print -delete
	return 0
}

sync_dropbox() {
	local -r archive_d="$1"
	local -r homepage_d="$2"
	local -r dropbox_d=~/Dropbox/homepage
	[[ -d "$dropbox_d" ]] || { printf "No Dropbox directory found.\n"; return 0; }
	printf "\n%sSynchronizing homepage archive with Dropbox...%s\n" "$lightyellow" "$normal"
	rsync -av --delete --exclude '.git' --exclude '.gitignore' "$homepage_d"/ "$archive_d"/ "$dropbox_d"
	return 0
}

process_homepage() {
	local -r main_host="hp-800g2-sff"
	local -r local_host="${HOSTNAME:-$(hostname)}"
	if [[ "$local_host" != "$main_host" ]]; then
		printf "%sScript must be run from %s.\n" "$RED_WARNING" "$main_host" >&2
		return "$E_INVALID_HOST"
	fi
	local -r homepage_dir=~/gitea/homepage
	local -r archive_dir=~/Downloads/archives/homepage
	[[ -d "$homepage_dir" ]] || mkdir "$homepage_dir"
	[[ -d "$archive_dir" ]] || mkdir "$archive_dir"
	check_package rsync
	printf "%sArchiving homepage files...%s\n" "$orange" "$normal"
	remove_backup_files "$homepage_dir"
	archive_homepage_repo "$archive_dir"
	sync_dropbox "$homepage_dir" "$archive_dir"
	return 0
}

main() {
	local -r script="${0##*/}"
	local -r version="7.4.26196"
	local -i exit_code=0
	process_homepage
	exit_code="$?"
	over_line "$script $version" "-"
	exit "$exit_code"
}

main "$@"

## Source function library ##
# shellcheck source=/home/rick/bin/functionlib
source ~/bin/functionlib || { printf "\e[91mERROR:\e[0m Unable to source functionlib\n"; exit 1; }

## Global Variables ##

EC=0

## Functions ##

connect_server() {
	local server="${1}.local"
	printf "%sConnecting to %s ...%s\n" "$lightyellow" "$server" "$normal"
	ssh "$server"
}

connect_server_x() {
	local server="${1}.local"
	printf "%sConnecting to %s (X11 forwarding) ...%s\n" "$lightyellow" "$server" "$normal"
	ssh -X "$server"
}

fuzzy_server() {
	local local_host="${HOSTNAME:-$(hostname)}"
	local FMENU="fzf --header=$script \
           --layout=reverse \
           --exact \
           --border=bold \
           --border=rounded \
           --margin=5% \
           --color=dark \
           --height=95% \
           --info=hidden \
           --header-first \
           --bind change:top \
           --prompt"
local -r servers=(
		hp-800g2-sff
		hp-6005
		e6500-deb
		probook-6570b
		hp-8300
		dell-9020
		hp-8300-usdt
		hp-800-g1-usdt
		hp-800-g1-dm
		probook-6570
		hp-probook-6570
		hp-850-g3
		hp-2560p e-475m
	)
	local server
	server=$($FMENU "Choose the remote server: " < <(printf "%s\n" "${servers[@]}"))
	[[ "$local_host" == "$server" ]] && { printf "Attempting to connect to local client.\n" >&2; EC="$E_INVALID_HOST"; return; }
	[[ "$server" ]] || { printf "No server selected.\n"; return; }
	if default_no "Enable X11 forwarding?"; then
		printf '\e[A\e[K'
		connect_server_x "$server"
	else
		printf '\e[A\e[K'
		connect_server "$server"
	fi
}

main() {
	local -r script="${0##*/}"
	local -r version="4.1.26160"
	check_package fzf
	clearscreen
	fuzzy_server
  over_line "$script $version"
	exit "$EC"
}

## Execution ##

main "$@"

## Source function library ##
# shellcheck source=/home/rick/bin/functionlib.bash
source ~/bin/functionlib.bash || { printf "\e[91mERROR:\e[0m Unable to source functionlib.bash\n"; exit 1; }

help() {
  local -r script="$1"
  local -r version="$2"
	local -i errcode="${3:-1}"
	local -r updated="24 Jul 2026"
	cat << _HELP_
${orange}$script${normal} $version ($updated)
Installs UFW on Debian, BunsenLabs, and MX Linux systems.
UFW/GUFW is installed by default in Linux Mint, LMDE, and Ubuntu.

${green}Usage:${normal} $script [-adhinrst]
${orange}Available options:${normal}
  -a  Add default rules for CUPS and SSH (Gitea/XRDP if installed)
  -d  Delete rules by rule number
  -h  Show this help message and exit
  -i  Install UFW on a Debian-based system
  -n  Add New rules
  -r  Remove UFW from a Debian-based system
  -s  UFW Status
  -t  Toggle Enable/Disable UFW
_HELP_
  exit "$errcode"
}

install_ufw() {
  sudo_login 2
  printf "Installing UFW (Uncomplicated Firewall)...\n"
  sudo apt-get install ufw -yy
  if ! installed ufw; then
    printf "%s UFW installation failed.\n" "$RED_ERROR" >&2
    return "$E_INSTALLATION"
  fi
  add_default_rules
  sudo ufw status verbose
  printf "UFW %s installed and configured.\n" "$(ufw_version)"
  return 0
}

remove_ufw() {
  if ! is_debian; then
    printf "Not a Debian system. UFW will not be removed.\n"
    return 0
  fi
  sudo_login 2
  printf "Removing UFW (Uncomplicated Firewall) version %s...\n" "$(ufw_version)"
  sudo ufw reset  # disable UFW and delete all active rules
  sudo  apt-get purge ufw
  return "$?"
}

add_default_rules() {
  sudo_login 2
  printf "Adding rules for CUPS, SSH, ...\n"
  sudo sed -i '/IPV6=no/s/no/yes/' /etc/default/ufw
  sudo ufw allow from 192.168.0.0/24 to any port 22 comment 'SSH' && printf "SSH (port 22) allowd on 192.168.0.0.\n"
  sudo ufw allow from 192.168.0.0/24 to any port 631 comment 'CUPS' && printf "CUPS (port 631) allowed on 192.168.0.0.\n"
  if exists gitea; then
    sudo ufw allow 3000/tcp comment 'GITEA' && printf "GITEA (port 3000) allowed.\n"
  fi
  if installed xrdp; then
    sudo ufw allow 3389/tcp comment 'XRDP' && printf "XRDP (port 3389) allowed.\n"
  fi
  ufw_active || sudo ufw enable
  return 0
}

add_new_rules() {
  local rule="deny foo"
  sudo_login 2
  sudo ufw status
  printf "Add new rules in the following format:\n"
  printf "allow/deny <protocol> or allow/deny <port-number>\n"
  while [[ "$rule" != "" ]]; do
    read -rp "Rule to be added (done to exit): " rule
    [[ "$rule" != "" ]] && sudo ufw delete "$rule"
  done
  ufw_active || sudo ufw enable
  return 0
}

delete_rules() {
  local -i rule=0
  sudo_login 2
  while [[ "$rule" != "" ]]; do
    sudo ufw status numbered
    read -rp "Rule to be removed (by number): " rule
    [[ "$rule" != "" ]] && sudo ufw delete "$rule"
  done
  ufw_active || sudo ufw enable
  return 0
}

toggle_ufw() {
  sudo_login 2
  if ufw_active; then
    sudo ufw disable
    printf "UFW has been disabled.\n"
  else
    sudo ufw enable
    printf "UFW is now enabled.\n"
  fi
  return 0
}

ufw_active() {
  grep -qw active < <(sudo /usr/sbin/ufw status) && return "$TRUE" || return "$FALSE"
}

ufw_version() {
  awk 'NR==1 {print $NF}' < <(/usr/sbin/ufw version)
  return 0
}

main() {
  local -r script="${0##*/}"
  local -r version="2.3.26205"
  local -i exit_code=0
  local opt OPTARG OPTIND
  local -i noOpt=1
  local -r optstr=":adhinrst"
  while getopts "$optstr" opt; do
    case "$opt" in
      a )
        if installed ufw; then
          add_default_rules
        else
          printf "UFW is not installed.\n" >&2
        fi
        ;;
      d )
        if installed ufw; then
          delete_rules
        else
          printf "UFW is not installed.\n" >&2
        fi
        ;;
      h )
        help "$script" "$version" 0
        ;;
      i )
        if installed ufw; then
          printf "UFW %s is already installed.\n" "$(ufw_version)" >&2
        else
          install_ufw
        fi
        ;;
      n )
        if installed ufw; then
          add_new_rules
        else
          printf "UFW is not installed.\n" >&2
        fi
        ;;
      r )
        if installed ufw; then
          remove_ufw
        else
          printf "UFW is not installed.\n" >&2
        fi
        ;;
      s )
        if installed ufw; then
          sudo_login 2
          printf "UFW %s\n" "$(ufw_version)"
          sudo ufw status verbose
        else
          printf "UFW is not installed.\n" >&2
        fi
        ;;
      t )
        if installed ufw; then
          toggle_ufw
        else
          printf "UFW is not installed.\n" >&2
        fi
        ;;
      ? )
        printf "%s Invalid option -%s\n" "$RED_ERROR" "$OPTARG" >&2
        help "$script" "$version" "$E_INVALID_ARG"
    esac
    exit_code="$?"
    noOpt=0
  done
  [[ "$noOpt" = 1 ]] && { printf "%s No argument passed.\n" "$RED_ERROR" >&2; help "$script" "$version" "$E_MISSING_ARG"; }
  shift "$(( OPTIND - 1 ))"
  over_line "$script $version"
  exit "$exit_code"
}

main "$@"

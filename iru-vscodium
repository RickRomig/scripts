## Source function library ##
# shellcheck source=/home/rick/bin/functionlib.bash
source ~/bin/functionlib.bash || { printf "\e[91mERROR:\e[0m Unable to source functionlib.bash\n"; exit 1; }

help() {
  local -r script="$1"
  local -r version="$2"
	local -r errcode="${3:-1}"
	local updated="21 Jul 2026"
	cat << _HELP_
${orange}$script${normal} $version ($updated)
Installs, configures, updates,  removes the VSCodium editor.

${green}Usage:${normal} $script [-hiru]
${orange}Available options:${normal}
  -h  Show this help message and exit.
  -i  Installs the VSCodium editor.
  -r  Removes the VSCodium editor from the system.
  -u  Updates the VSCodium editor to the latest GitHub release.
_HELP_
  exit "$errcode"
}

# shellcheck disable=SC2317 # Don't warn about unreachable commands in this function
# ShellCheck may incorrectly believe that code is unreachable if it's invoked by variable name or in a trap.
cleanup() {
  [[ -d "$TMP_DIR" ]] && rm -rf "$TMP_DIR"
  [[ -f "$TMP_FILE" ]] && rm -f "$TMP_FILE"
}

codium_version() {
	head -n1 < <(codium --version)
  return 0
}

convert_compare() {
  local newVer="$1"
  local curVer="$2"
  local newer="$FALSE"
	local new_arr=()
	local cur_arr=()
  local -i index
	IFS="." read -ra new_arr <<< "$newVer"
	IFS="." read -ra cur_arr <<< "$curVer"
	for (( index=0; index <=2; index++)) ; do
		if [[ "${new_arr[index]}" > "${cur_arr[index]}" ]]; then
      newer="$TRUE"
      break
    fi
	done
	return "$newer"
}

newest_version() {
  local -r gh_url="$1"
  local new_ver
  wget -qO "$TMP_FILE" "$gh_url"
  new_ver=$(sed 's/^v//' < <(awk -F'/' '/download/ && /amd64.deb/ {print $8;exit}' "$TMP_FILE"))
  echo "$new_ver"
  return 0
}

compare_versions() {
	local -r new_ver="$1"
  local -r gh_url="$2"
  local cur_ver
  cur_ver=$(codium_version)
  printf "Comparing current and newest versions...\n"
  if [[ -z "$new_ver" ]]; then
    printf "%s No download available. Try again later." "$RED_ERROR" >&2
    return "$E_DOWNLOAD"
  elif convert_compare "$new_ver" "$cur_ver"; then
    printf "%sInstalled version of VSCodium is %s, updating to %s...%s\n" "$lightyellow" "$cur_ver" "$new_ver" "$normal"
    install_vscodium "$new_ver" "$gh_url"
  else
    printf "%sVSCodium %s is the current version. No update required.%s\n" "$lightyellow" "$cur_ver" "$normal"
  fi
  return 0
}

install_vscodium() {
	local -r new_ver="$1"
	local -r gh_url="$2"
 local new_pkg="codium_${new_ver}_amd64.deb"
  if [[ -z "$new_ver" ]]; then
    printf "%s No download available. Try again later." "$RED_ERROR" >&2
    return "$E_DOWNLOAD"
  fi
  printf "Downloading VSCodium %s from the VSCodium GitHub repository..." "$new_ver"
  dots "." &
  DOTS_PID="$!"
  wget -q -P "$TMP_DIR/" "$gh_url/download/$new_ver/$new_pkg"
  kill_dots
  printf "Installing VSCodium %s...\n" "$new_ver"
  sudo_login 2
	sudo dpkg -i "$TMP_DIR/$new_pkg"; sudo apt-get install --fix-broken
  if [[ "$(codium_version)" != "$new_ver" ]]; then
    printf "%s VSCodium installation failed.\n" "$RED_ERROR" >&2
    return "$E_INSTALLATION"
  fi
  printf "%sVSCodium %s successfully installed.%s\n" "$lightyellow" "$(codium_version)" "$normal"
  return 0
}

remove_vscodium() {
  sudo_login 2
  printf "Removing the VSCodium editor %s...\n" "$(codium_version)"
  sudo dpkg --remove codium
  [[ -L ~/.config/VSCodium/User/settings.json ]] && unlink ~/.config/VSCodium/User/settings.json
  find ~/ -maxdepth 3 -type d -path "$HOME/Downloads" -prune -o -path "$HOME/gitea" -prune -o -type d -name VSCodium -exec rm -rf {} \;
  find /etc/apt -type f -iname "*codium*" -exec sudo rm -f {} \;
  find /usr/share -maxdepth 3 -type f,d -iname "*codium*" -exec sudo rm -rf {} \;
  printf "VSCodium editor has been removed.\n"
  return 0
}

apply_settings() {
  local repository=~/Downloads/configs
  [[ -d ~/gitea/configs ]] && repository=~/gitea/configs
  if [[ ! -d "$repository" ]]; then
    printf "%s Cloned repository not found!\n" "$RED_WARNING" >&2
    return "$E_FILENOTFOUND"
  fi
  printf "Applying VSCodium settings...\n"
  [[ -d ~/.config/VSCodium/User ]] && mkdir -p ~/.config/VSCodium/User
  [[ -f ~/.config/VSCodium/User/settings.json ]] && rm ~/.config/VSCodium/User/settings.json
	[[ -d ~/gitea/configs ]] && ln -sv ~/gitea/configs/VSCodium/User/settings.json ~/.config/VSCodium/User/settings.json
	[[ -d ~/Downloads/configs ]] && ln -sv ~/Downloads/configs/VSCodium/User/settings.json ~/.config/VSCodium/User/settings.json
  printf "VSCodium settings applied.\n"
  return 0
}

main() {
  local -r script="${0##*/}"
  local -r version="4.6.26202"
	local -i exit_code=0
  local -r gh_url="https://github.com/VSCodium/vscodium/releases"
  local opt new_ver OPTARG OPTIND
  local -i noOpt=1
  local -r optstr=":hiru"
  while getopts "$optstr" opt; do
	  case "$opt" in
		  h )
			  help "$script" "$version" 0
        ;;
		  i )
        if exists codium; then
          printf "VSCodium %s is already installed.\n" "$(codium_version)" >&2
        else
          TMP_FILE=$(mktemp) || die "Failed to create temporary file." "$E_TEMP_FILE"
          TMP_DIR=$(mktemp -d) || die "Failed to create temporary directory." "$E_TEMP_DIR"
			    trap cleanup EXIT
			    new_ver="$(newest_version "$gh_url")"
          printf "%sInstalling VSCodium %s...%s\n" "$lightyellow" "$new_ver" "$normal"
			    install_vscodium "$new_ver" "$gh_url" && apply_settings
        fi
        ;;
		  r )
        if exists codium; then
          remove_vscodium
        else
          printf "VSCodium is not installed.\n" >&2
        fi
        ;;
		  u )
        if exists codium; then
          TMP_FILE=$(mktemp) || die "Failed to create temporary file." "$E_TEMP_FILE"
          TMP_DIR=$(mktemp -d) || die "Failed to create temporary directory." "$E_TEMP_DIR"
			    trap cleanup EXIT
			    new_ver="$(newest_version "$gh_url")"
			    compare_versions "$new_ver" "$gh_url"
        else
          printf "VSCodium is not installed.\n" >&2
        fi
        ;;
		  ? )
        printf "%s Invalid option -%s\n" "$RED_ERROR" "$OPTARG" >&2
			  help "$script" "$version" "$E_INVALID_ARG"
	  esac
    exit_code="$?"
	  noOpt=0
  done
  [[ "$noOpt" = 1 ]] && { printf "%s No argument passed.\n" "$RED_ERROR" >&2; help "$script" "$version" "$E_MISSING_ARG"; }
  shift "$(( OPTIND - 1 ))"
  over_line "$script $version"
  exit "$exit_code"
}

## Execution ##

main "$@"
